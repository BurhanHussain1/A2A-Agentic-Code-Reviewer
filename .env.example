# Copy this file to `.env` and fill in real values:
#   cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
# `.env` is git-ignored, so your real key never leaves your machine.

# --- LLM (each agent calls OpenAI internally) ---
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini

# --- Networking ---
# One host shared by every agent; each agent gets its own port.
# The orchestrator derives each specialist's URL from these.
HOST=127.0.0.1
ORCHESTRATOR_PORT=8000
SECURITY_AGENT_PORT=8001
STYLE_AGENT_PORT=8002

# --- Misc ---
LOG_LEVEL=INFO
